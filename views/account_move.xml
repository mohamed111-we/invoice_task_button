<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_move_inherit_form" model="ir.ui.view">
            <field name="name">account.move.inherit.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='state'][1]" position="attributes">
                    <attribute name="statusbar_visible">draft,first_confirm,posted</attribute>
                </xpath>
                <xpath expr="//field[@name='state'][2]" position="attributes">
                    <attribute name="statusbar_visible">draft,first_confirm,posted</attribute>
                </xpath>

                <xpath expr="//button[@name='action_post'][1]" position="before">
                    <button name="action_first_confirm"
                            string="First Confirm"
                            type="object"
                            invisible="state == 'first_confirm'"
                            groups="invoice_task_button.group_show_invoice_button"
                            class="oe_highlight"/>
                </xpath>

                <xpath expr="//button[@name='action_post'][1]" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//button[@name='action_post'][2]" position="attributes">
                    <attribute name="groups">invoice_task_button.group_show_invoice_button</attribute>
                    <attribute name="invisible">state != 'first_confirm'</attribute>
                </xpath>

                <xpath expr="//button[@name='button_cancel'][1]" position="attributes">
                    <attribute name="groups">invoice_task_button.group_show_invoice_button</attribute>
                </xpath>
                <xpath expr="//button[@name='button_cancel'][2]" position="attributes">
                    <attribute name="groups">invoice_task_button.group_show_invoice_button</attribute>
                </xpath>

            </field>
        </record>
    </data>
</odoo>